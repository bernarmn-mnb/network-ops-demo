# =============================================================================
# Environment Variables for Cloud Run Deployment
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED]
# Optional variables show their defaults
#
# See deploy/env-config.sh for full documentation.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Must be set for deployment
# -----------------------------------------------------------------------------

# [REQUIRED] Elasticsearch URL for data storage
# Example: https://my-cluster.es.us-central1.gcp.cloud.es.io
ELASTICSEARCH_URL=

# [REQUIRED] API key for Elasticsearch with search permissions
ELASTIC_API_KEY=

# -----------------------------------------------------------------------------
# GCP CONFIGURATION - Optional, have sensible defaults
# -----------------------------------------------------------------------------

# GCP project ID for deployment
# Default: elastic-sa
# GCP_PROJECT_ID=elastic-sa

# GCP region for Cloud Run
# Default: us-central1
# GCP_REGION=us-central1

# Cloud Run service name
# Default: my-demo
# SERVICE_NAME=my-demo

# URL base path (must match Load Balancer URL map)
# Default: /demo/
# BASE_PATH=/demo/

# -----------------------------------------------------------------------------
# SEARCH CONFIGURATION
# -----------------------------------------------------------------------------

# Elasticsearch index for data
# Default: products
# SEARCH_INDEX=products

# -----------------------------------------------------------------------------
# OBSERVABILITY CLUSTER - For APM/traces
# Defaults to same as main cluster if not specified
# -----------------------------------------------------------------------------

# Elasticsearch URL for APM/traces (can be separate from data cluster)
# Default: same as ELASTICSEARCH_URL
# MONITORING_ELASTICSEARCH_URL=

# API key for monitoring cluster
# Default: same as ELASTIC_API_KEY
# MONITORING_ELASTIC_API_KEY=

# Elastic APM OTLP endpoint (leave empty to disable tracing)
# Example: https://xxx.apm.us-central1.gcp.cloud.es.io:443
# OTEL_EXPORTER_OTLP_ENDPOINT=

# APM secret token for authentication
# ELASTIC_APM_SECRET_TOKEN=

# -----------------------------------------------------------------------------
# SCALING CONFIGURATION
# -----------------------------------------------------------------------------

# Minimum Cloud Run instances (0 = scale to zero)
# Default: 0
# MIN_INSTANCES=0

# Maximum Cloud Run instances
# Default: 1 (increase for production)
# MAX_INSTANCES=1
