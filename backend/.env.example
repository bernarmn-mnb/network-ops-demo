# Elastic Agent Builder Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: Elastic Cloud / Agent Builder
# =============================================================================

# Kibana URL (required)
# Get this from your Elastic Cloud deployment or self-hosted Kibana
# Example: https://my-deployment.kb.us-west2.gcp.elastic-cloud.com
KIBANA_URL=

# Elastic API Key (required)
# Create in Kibana: Stack Management > API Keys
# Needs permissions for Agent Builder APIs
ELASTIC_API_KEY=

# Agent ID (required)
# Get from Agent Builder: Select your agent > Copy ID from URL or settings
AGENT_ID=

# =============================================================================
# OPTIONAL: Elasticsearch Direct Access
# =============================================================================

# Elasticsearch URL (optional, for direct ES queries)
# Example: https://my-deployment.es.us-west2.gcp.elastic-cloud.com
ELASTICSEARCH_URL=

# =============================================================================
# OPTIONAL: LLM Proxy (for A2A multi-agent features)
# =============================================================================

# LLM Proxy URL (optional, enables A2A coordinator)
# If using Elastic's AI features or a custom LLM proxy
LLM_PROXY_URL=

# LLM Proxy API Key (optional)
LLM_PROXY_API_KEY=

# =============================================================================
# OPTIONAL: Server Configuration
# =============================================================================

# Backend server host (default: 0.0.0.0)
HOST=0.0.0.0

# Backend server port (default: 8001)
# Note: Dynamic port allocation may override this
PORT=8001

# Frontend port (default: 3000)
# Used for CORS configuration
FRONTEND_PORT=3000

# Additional CORS origins (comma-separated)
# Example: https://my-app.example.com,https://staging.example.com
CORS_ORIGINS=
