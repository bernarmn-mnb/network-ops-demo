# Elastic Agent Builder Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: Elastic Cloud / Agent Builder
# =============================================================================

# Kibana URL (required for Agent Builder features)
# Get this from your Elastic Cloud deployment or self-hosted Kibana
# Example: https://my-deployment.kb.us-west2.gcp.elastic-cloud.com
KIBANA_URL=

# Elastic API Key (required)
# Create in Kibana: Stack Management > API Keys
# Needs permissions for Agent Builder APIs and Elasticsearch access
ELASTIC_API_KEY=

# Agent ID (required for Agent Builder chat)
# Get from Agent Builder: Select your agent > Copy ID from URL or settings
AGENT_ID=

# Connector ID (optional - override agent's default LLM connector)
# Useful for model bakeoffs: switch between Claude, GPT, Gemini without code changes
# Get from Kibana: Stack Management > Connectors > Select connector > Copy ID
# If empty, the agent uses whichever connector it was configured with
#
# Common pre-configured connector IDs on Elastic Serverless:
#   OpenAI-GPT-4-1-Mini          (fast, cheap — good default for demos)
#   Anthropic-Claude-Haiku-4-5   (fast, good quality)
#   Google-Gemini-2-5-Flash      (fastest)
#   Anthropic-Claude-Sonnet-4-5  (higher quality, slower)
#   OpenAI-GPT-4-1               (balanced)
CONNECTOR_ID=

# =============================================================================
# WORKFLOWS (optional - for Elastic Workflows automation)
# =============================================================================

# Workflows API Key (needs workflowsManagement Kibana privilege)
# Required for creating, running, and managing workflows via the proxy API.
# If empty, the app auto-loads ADMIN_API_KEY from .secrets/ootb-admin.env.
# You only need to set this if you have a dedicated workflows key.
WORKFLOWS_API_KEY=

# Agent Management API Key (needs agentBuilder:manageTools Kibana privilege)
# Required for creating, updating, and deleting agents and tools via the proxy API.
# If empty, the app auto-loads ADMIN_API_KEY from .secrets/ootb-admin.env.
# Read operations (list/get agents) use the standard ELASTIC_API_KEY above.
AGENT_MANAGEMENT_API_KEY=

# =============================================================================
# ELASTICSEARCH CONNECTION (required for search features)
# =============================================================================

# Option 1: Cloud ID (recommended for Elastic Cloud)
# Find in Elastic Cloud console: Deployments > Your Deployment > Cloud ID
ELASTIC_CLOUD_ID=

# Option 2: Direct URL (for self-hosted or if Cloud ID not available)
# Example: https://my-deployment.es.us-west2.gcp.elastic-cloud.com:443
ELASTICSEARCH_URL=

# =============================================================================
# SEARCH CONFIGURATION
# =============================================================================

# Elasticsearch index to search (default: ootb-products)
# This should match your data index name
# OOTB indices: ootb-products, ootb-knowledge, ootb-support, ootb-stores
SEARCH_INDEX=ootb-products

# Visual Search (Jina CLIP v2 - text-to-image and image-to-image kNN)
# Get API key from https://jina.ai/
JINA_API_KEY=

# Elasticsearch index for visual search (default: products)
# Must have a dense_vector field with Jina CLIP v2 embeddings
VISUAL_SEARCH_INDEX=products

# =============================================================================
# OPENTELEMETRY / APM (optional - for observability)
# =============================================================================

# Set to 'false' to explicitly disable OTel (default: enabled if endpoint set)
# OTEL_ENABLED=true

# OTLP Endpoint for traces
# Elastic Cloud APM: https://xxx.apm.region.gcp.cloud.es.io:443
OTEL_EXPORTER_OTLP_ENDPOINT=

# OTLP Headers for authentication
# Format: Authorization=Bearer <your-secret-token>
# Get token from Kibana: Observability > APM > Settings > Agent keys
OTEL_EXPORTER_OTLP_HEADERS=

# Service identification (optional, has defaults)
OTEL_SERVICE_NAME=elastic-demo-starter
OTEL_SERVICE_VERSION=1.0.0
OTEL_DEPLOYMENT_ENVIRONMENT=development

# =============================================================================
# LLM PROXY (optional - for A2A multi-agent features)
# =============================================================================

# LLM Proxy URL (enables A2A coordinator agent)
LLM_PROXY_URL=

# LLM Proxy API Key
LLM_PROXY_API_KEY=

# LLM Model to use (default: gpt-4)
LLM_PROXY_MODEL=gpt-4

# =============================================================================
# SERVER CONFIGURATION (optional - has defaults)
# =============================================================================

# Backend server host (default: 0.0.0.0)
HOST=0.0.0.0

# Backend server port (default: 8001)
PORT=8001

# Frontend port (default: 3000)
FRONTEND_PORT=3000

# Additional CORS origins (comma-separated)
CORS_ORIGINS=
