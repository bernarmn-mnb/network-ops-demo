#!/bin/bash

# =============================================================================
# Dev Server Management Script
# =============================================================================
# Usage:
#   ./dev start         - Start backend and frontend servers
#   ./dev stop          - Stop all servers
#   ./dev restart       - Restart all servers
#   ./dev status        - Check if servers are running
#   ./dev logs          - Show server logs (tail -f, follows indefinitely)
#   ./dev logs-snapshot - Show recent logs and exit (non-blocking)
#   ./dev open          - Open browser to frontend
# =============================================================================

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
DIM='\033[2m'
NC='\033[0m'

# PID files location
PID_DIR=".dev-pids"
BACKEND_PID_FILE="$PID_DIR/backend.pid"
FRONTEND_PID_FILE="$PID_DIR/frontend.pid"
LOG_DIR=".dev-logs"

# Default ports
DEFAULT_BACKEND_PORT=8001
DEFAULT_FRONTEND_PORT=3000

# =============================================================================
# Helper Functions
# =============================================================================

ensure_dirs() {
    mkdir -p "$PID_DIR" "$LOG_DIR"
}

is_running() {
    local pid_file=$1
    if [ -f "$pid_file" ]; then
        local pid=$(cat "$pid_file")
        if ps -p "$pid" > /dev/null 2>&1; then
            return 0
        fi
    fi
    return 1
}

get_pid() {
    local pid_file=$1
    if [ -f "$pid_file" ]; then
        cat "$pid_file"
    fi
}

# Check if a port is available (not in use)
is_port_available() {
    local port=$1
    ! lsof -i:"$port" > /dev/null 2>&1
}

# Find an available port starting from the given port
find_available_port() {
    local start_port=$1
    local max_attempts=100
    local port=$start_port
    
    for ((i=0; i<max_attempts; i++)); do
        if is_port_available "$port"; then
            echo "$port"
            return 0
        fi
        ((port++))
    done
    
    echo ""
    return 1
}

# Read ports from .env file
read_env_ports() {
    BACKEND_PORT=$DEFAULT_BACKEND_PORT
    FRONTEND_PORT=$DEFAULT_FRONTEND_PORT
    
    if [ -f backend/.env ]; then
        while IFS='=' read -r key value; do
            case "$key" in
                PORT) BACKEND_PORT="$value" ;;
                FRONTEND_PORT) FRONTEND_PORT="$value" ;;
            esac
        done < <(grep -E '^(PORT|FRONTEND_PORT)=' backend/.env 2>/dev/null || true)
    fi
}

# Update a single value in .env file
update_env_value() {
    local key=$1
    local value=$2
    local env_file="backend/.env"
    
    if [ ! -f "$env_file" ]; then
        return 1
    fi
    
    if grep -q "^${key}=" "$env_file"; then
        # Update existing key
        sed -i.bak "s|^${key}=.*|${key}=${value}|" "$env_file"
        rm -f "${env_file}.bak"
    else
        # Add new key
        echo "${key}=${value}" >> "$env_file"
    fi
}

# =============================================================================
# Commands
# =============================================================================

cmd_start() {
    ensure_dirs
    read_env_ports
    
    echo -e "${BLUE}🚀 Starting Elastic Demo Starter...${NC}"
    echo ""
    
    local ports_changed=false
    
    # -------------------------------------------------------------------------
    # Start Backend
    # -------------------------------------------------------------------------
    if is_running "$BACKEND_PID_FILE"; then
        echo -e "${YELLOW}⚠️  Backend already running (PID: $(get_pid $BACKEND_PID_FILE))${NC}"
    else
        # Check if configured port is available
        if ! is_port_available "$BACKEND_PORT"; then
            local old_port=$BACKEND_PORT
            BACKEND_PORT=$(find_available_port "$BACKEND_PORT")
            
            if [ -z "$BACKEND_PORT" ]; then
                echo -e "${RED}❌ Could not find available port for backend (tried $old_port-$((old_port+99)))${NC}"
                exit 1
            fi
            
            echo -e "${YELLOW}⚠️  Port $old_port in use, using $BACKEND_PORT instead${NC}"
            update_env_value "PORT" "$BACKEND_PORT"
            ports_changed=true
        fi
        
        echo -e "Starting backend on port ${GREEN}$BACKEND_PORT${NC}..."
        cd backend
        PORT=$BACKEND_PORT nohup ./venv/bin/python run.py > "../$LOG_DIR/backend.log" 2>&1 &
        echo $! > "../$BACKEND_PID_FILE"
        cd ..
        echo -e "${GREEN}✅ Backend started${NC} (PID: $(get_pid $BACKEND_PID_FILE))"
    fi
    
    # -------------------------------------------------------------------------
    # Start Frontend
    # -------------------------------------------------------------------------
    if is_running "$FRONTEND_PID_FILE"; then
        echo -e "${YELLOW}⚠️  Frontend already running (PID: $(get_pid $FRONTEND_PID_FILE))${NC}"
    else
        # Check if configured port is available
        if ! is_port_available "$FRONTEND_PORT"; then
            local old_port=$FRONTEND_PORT
            FRONTEND_PORT=$(find_available_port "$FRONTEND_PORT")
            
            if [ -z "$FRONTEND_PORT" ]; then
                echo -e "${RED}❌ Could not find available port for frontend (tried $old_port-$((old_port+99)))${NC}"
                exit 1
            fi
            
            echo -e "${YELLOW}⚠️  Port $old_port in use, using $FRONTEND_PORT instead${NC}"
            update_env_value "FRONTEND_PORT" "$FRONTEND_PORT"
            ports_changed=true
        fi
        
        echo -e "Starting frontend on port ${GREEN}$FRONTEND_PORT${NC}..."
        cd frontend
        # Use --strictPort so Vite fails instead of silently switching ports
        # Pass BACKEND_PORT so vite proxy knows where to proxy API requests
        VITE_BACKEND_PORT=$BACKEND_PORT nohup yarn dev --port $FRONTEND_PORT --strictPort > "../$LOG_DIR/frontend.log" 2>&1 &
        echo $! > "../$FRONTEND_PID_FILE"
        cd ..
        echo -e "${GREEN}✅ Frontend started${NC} (PID: $(get_pid $FRONTEND_PID_FILE))"
    fi
    
    # -------------------------------------------------------------------------
    # Summary
    # -------------------------------------------------------------------------
    echo ""
    if [ "$ports_changed" = true ]; then
        echo -e "${YELLOW}📝 Updated backend/.env with new port(s)${NC}"
    fi
    
    echo -e "${GREEN}Servers starting...${NC}"
    echo -e "   Backend:  ${BLUE}http://localhost:$BACKEND_PORT${NC}"
    echo -e "   Frontend: ${BLUE}http://localhost:$FRONTEND_PORT${NC}"
    echo ""
    echo -e "Run ${YELLOW}./dev logs${NC} to see output"
    echo -e "Run ${YELLOW}./dev stop${NC} to stop servers"
    
    # Wait a moment then check if they're actually running
    sleep 2
    local failed=false
    
    if ! is_running "$BACKEND_PID_FILE"; then
        echo ""
        echo -e "${RED}⚠️  Backend failed to start${NC}"
        echo -e "${DIM}   Check: cat $LOG_DIR/backend.log${NC}"
        failed=true
    fi
    
    if ! is_running "$FRONTEND_PID_FILE"; then
        echo ""
        echo -e "${RED}⚠️  Frontend failed to start${NC}"
        echo -e "${DIM}   Check: cat $LOG_DIR/frontend.log${NC}"
        failed=true
    fi
    
    if [ "$failed" = false ]; then
        # Save the actual ports being used for other commands
        echo "$BACKEND_PORT" > "$PID_DIR/backend.port"
        echo "$FRONTEND_PORT" > "$PID_DIR/frontend.port"
    fi
}

cmd_stop() {
    read_env_ports
    
    echo -e "${BLUE}Stopping servers...${NC}"
    
    if is_running "$BACKEND_PID_FILE"; then
        local pid=$(get_pid "$BACKEND_PID_FILE")
        kill "$pid" 2>/dev/null || true
        rm -f "$BACKEND_PID_FILE"
        echo -e "${GREEN}✅ Backend stopped${NC}"
    else
        echo -e "${YELLOW}Backend not running${NC}"
    fi
    
    if is_running "$FRONTEND_PID_FILE"; then
        local pid=$(get_pid "$FRONTEND_PID_FILE")
        kill "$pid" 2>/dev/null || true
        # Also kill any child processes (vite spawns children)
        pkill -P "$pid" 2>/dev/null || true
        rm -f "$FRONTEND_PID_FILE"
        echo -e "${GREEN}✅ Frontend stopped${NC}"
    else
        echo -e "${YELLOW}Frontend not running${NC}"
    fi
    
    # Clean up port files
    rm -f "$PID_DIR/backend.port" "$PID_DIR/frontend.port"
    
    # Clean up any orphaned processes on our ports
    # Only kill if ports are defined
    if [ -n "$BACKEND_PORT" ]; then
        lsof -ti:"$BACKEND_PORT" 2>/dev/null | xargs kill 2>/dev/null || true
    fi
    if [ -n "$FRONTEND_PORT" ]; then
        lsof -ti:"$FRONTEND_PORT" 2>/dev/null | xargs kill 2>/dev/null || true
    fi
    
    echo -e "${GREEN}All servers stopped${NC}"
}

cmd_restart() {
    cmd_stop
    sleep 1
    cmd_start
}

cmd_status() {
    read_env_ports
    
    # Try to read actual running ports
    local actual_backend_port=$BACKEND_PORT
    local actual_frontend_port=$FRONTEND_PORT
    
    if [ -f "$PID_DIR/backend.port" ]; then
        actual_backend_port=$(cat "$PID_DIR/backend.port")
    fi
    if [ -f "$PID_DIR/frontend.port" ]; then
        actual_frontend_port=$(cat "$PID_DIR/frontend.port")
    fi
    
    echo -e "${BLUE}Server Status${NC}"
    echo ""
    
    if is_running "$BACKEND_PID_FILE"; then
        echo -e "Backend:  ${GREEN}● Running${NC} (PID: $(get_pid $BACKEND_PID_FILE), port $actual_backend_port)"
    else
        echo -e "Backend:  ${RED}○ Stopped${NC}"
    fi
    
    if is_running "$FRONTEND_PID_FILE"; then
        echo -e "Frontend: ${GREEN}● Running${NC} (PID: $(get_pid $FRONTEND_PID_FILE), port $actual_frontend_port)"
    else
        echo -e "Frontend: ${RED}○ Stopped${NC}"
    fi
    
    echo ""
    
    # Check if ports are actually listening
    if lsof -i:"$actual_backend_port" > /dev/null 2>&1; then
        echo -e "Port $actual_backend_port: ${GREEN}listening${NC}"
    else
        echo -e "Port $actual_backend_port: ${RED}not listening${NC}"
    fi
    
    if lsof -i:"$actual_frontend_port" > /dev/null 2>&1; then
        echo -e "Port $actual_frontend_port: ${GREEN}listening${NC}"
    else
        echo -e "Port $actual_frontend_port: ${RED}not listening${NC}"
    fi
}

cmd_logs() {
    ensure_dirs
    
    echo -e "${BLUE}Tailing logs (Ctrl+C to exit)${NC}"
    echo -e "Backend log:  $LOG_DIR/backend.log"
    echo -e "Frontend log: $LOG_DIR/frontend.log"
    echo ""
    
    # Use tail to follow both log files
    tail -f "$LOG_DIR/backend.log" "$LOG_DIR/frontend.log" 2>/dev/null || {
        echo -e "${YELLOW}No logs yet. Start servers with: ./dev start${NC}"
    }
}

cmd_logs_snapshot() {
    local lines=${1:-50}
    ensure_dirs
    
    echo -e "${BLUE}=== Backend Logs (last $lines lines) ===${NC}"
    if [ -f "$LOG_DIR/backend.log" ]; then
        tail -n "$lines" "$LOG_DIR/backend.log" 2>/dev/null || echo "(empty)"
    else
        echo -e "${YELLOW}No backend log file${NC}"
    fi
    
    echo ""
    echo -e "${BLUE}=== Frontend Logs (last $lines lines) ===${NC}"
    if [ -f "$LOG_DIR/frontend.log" ]; then
        tail -n "$lines" "$LOG_DIR/frontend.log" 2>/dev/null || echo "(empty)"
    else
        echo -e "${YELLOW}No frontend log file${NC}"
    fi
}

cmd_open() {
    read_env_ports
    
    # Try to read actual running port
    local actual_frontend_port=$FRONTEND_PORT
    if [ -f "$PID_DIR/frontend.port" ]; then
        actual_frontend_port=$(cat "$PID_DIR/frontend.port")
    fi
    
    local url="http://localhost:$actual_frontend_port"
    echo -e "Opening ${BLUE}$url${NC}..."
    
    # Detect OS and open browser
    case "$(uname -s)" in
        Darwin*) open "$url" ;;
        Linux*) xdg-open "$url" 2>/dev/null || sensible-browser "$url" ;;
        MINGW*|CYGWIN*) start "$url" ;;
        *) echo "Please open $url in your browser" ;;
    esac
}

cmd_help() {
    read_env_ports
    
    echo "Elastic Demo Starter - Dev Server Manager"
    echo ""
    echo "Usage: ./dev <command>"
    echo ""
    echo "Commands:"
    echo "  start          Start servers in background (auto-finds available ports)"
    echo "  stop           Stop all servers"
    echo "  restart        Restart (only needed after .env or dependency changes)"
    echo "  status         Show if running, ports, PIDs"
    echo "  logs           Tail server logs (follows, use Ctrl+C to exit)"
    echo "  logs-snapshot  Show recent logs and exit (default: 50 lines)"
    echo "                 Usage: ./dev logs-snapshot [num_lines]"
    echo "  open           Open browser to frontend"
    echo ""
    echo "Both servers auto-reload on code changes - no restart needed!"
    echo ""
    echo "Configured Ports (from backend/.env):"
    echo "  Backend:  $BACKEND_PORT"
    echo "  Frontend: $FRONTEND_PORT"
    echo ""
    echo "If these ports are in use, available ports will be found automatically."
    echo ""
    echo "Typical workflow:"
    echo "  ./dev start        # Start once"
    echo "  ./dev open         # Open browser"
    echo "  # ... edit code, it auto-reloads ..."
    echo "  ./dev stop         # Done for the day"
}

# =============================================================================
# Main
# =============================================================================

case "${1:-help}" in
    start)   cmd_start ;;
    stop)    cmd_stop ;;
    restart) cmd_restart ;;
    status)  cmd_status ;;
    logs)    cmd_logs ;;
    logs-snapshot) cmd_logs_snapshot "${2:-50}" ;;
    open)    cmd_open ;;
    help|--help|-h) cmd_help ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo ""
        cmd_help
        exit 1
        ;;
esac
