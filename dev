#!/bin/bash

# =============================================================================
# Dev Server Management Script
# =============================================================================
# Usage:
#   ./dev start         - Start backend and frontend servers
#   ./dev stop          - Stop all servers
#   ./dev restart       - Restart all servers
#   ./dev status        - Check if servers are running
#   ./dev logs          - Show server logs (tail -f, follows indefinitely)
#   ./dev logs-snapshot - Show recent logs and exit (non-blocking)
#   ./dev open          - Open browser to frontend
#   ./dev verify-search  - Verify search endpoint returns results and aggregations
#   ./dev test-search    - Test semantic + keyword search quality
# =============================================================================

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
DIM='\033[2m'
NC='\033[0m'

# PID files location
PID_DIR=".dev-pids"
BACKEND_PID_FILE="$PID_DIR/backend.pid"
FRONTEND_PID_FILE="$PID_DIR/frontend.pid"
LOG_DIR=".dev-logs"

# Default ports
DEFAULT_BACKEND_PORT=8001
DEFAULT_FRONTEND_PORT=3000

# =============================================================================
# Helper Functions
# =============================================================================

ensure_dirs() {
    mkdir -p "$PID_DIR" "$LOG_DIR"
}

is_running() {
    local pid_file=$1
    if [ -f "$pid_file" ]; then
        local pid=$(cat "$pid_file")
        if ps -p "$pid" > /dev/null 2>&1; then
            return 0
        fi
    fi
    return 1
}

get_pid() {
    local pid_file=$1
    if [ -f "$pid_file" ]; then
        cat "$pid_file"
    fi
}

# Check if a port is available (not in use)
is_port_available() {
    local port=$1
    ! lsof -i:"$port" > /dev/null 2>&1
}

# Find an available port starting from the given port
find_available_port() {
    local start_port=$1
    local max_attempts=100
    local port=$start_port
    
    for ((i=0; i<max_attempts; i++)); do
        if is_port_available "$port"; then
            echo "$port"
            return 0
        fi
        ((port++))
    done
    
    echo ""
    return 1
}

# Read ports from .env file
read_env_ports() {
    BACKEND_PORT=$DEFAULT_BACKEND_PORT
    FRONTEND_PORT=$DEFAULT_FRONTEND_PORT
    
    if [ -f backend/.env ]; then
        while IFS='=' read -r key value; do
            case "$key" in
                PORT) BACKEND_PORT="$value" ;;
                FRONTEND_PORT) FRONTEND_PORT="$value" ;;
            esac
        done < <(grep -E '^(PORT|FRONTEND_PORT)=' backend/.env 2>/dev/null || true)
    fi
}

# Detect whether hive-mind content is available across layouts.
# Supports legacy patterns layout and newer skills/index layouts.
is_hive_mind_loaded() {
    [ -d "hive-mind/patterns" ] || \
    [ -f "hive-mind/.hive-mind-index.json" ] || \
    [ -d "hive-mind/skills" ] || \
    [ -d "hive-mind/.cursor/skills" ]
}

# Count issue rows from bd command output in a portable way.
count_bd_issue_lines() {
    local output
    local count

    output=$("$@" 2>/dev/null || true)
    count=$(printf '%s\n' "$output" | grep -cE '^[[:space:]]*([0-9]+\.|\[P[0-9]+\])' || true)
    echo "${count:-0}"
}

# Update a single value in .env file
update_env_value() {
    local key=$1
    local value=$2
    local env_file="backend/.env"
    
    if [ ! -f "$env_file" ]; then
        return 1
    fi
    
    if grep -q "^${key}=" "$env_file"; then
        # Update existing key
        sed -i.bak "s|^${key}=.*|${key}=${value}|" "$env_file"
        rm -f "${env_file}.bak"
    else
        # Add new key
        echo "${key}=${value}" >> "$env_file"
    fi
}

# =============================================================================
# Commands
# =============================================================================

check_dependencies() {
    local missing=()
    
    # Check for yarn or npm (need at least one)
    if ! command -v yarn &> /dev/null && ! command -v npm &> /dev/null; then
        missing+=("yarn or npm (Node.js package manager)")
    fi
    
    if [ ${#missing[@]} -gt 0 ]; then
        echo -e "${RED}❌ Missing dependencies:${NC}"
        for dep in "${missing[@]}"; do
            echo -e "   - $dep"
        done
        echo ""
        echo -e "${YELLOW}To fix:${NC}"
        if [[ " ${missing[*]} " =~ "yarn or npm" ]]; then
            echo -e "   Install Node.js: ${BLUE}https://nodejs.org/${NC}"
            echo -e "   Or with Homebrew: ${BLUE}brew install node${NC}"
        fi
        echo ""
        echo -e "Then run ${BLUE}./setup.sh${NC} to complete setup."
        exit 1
    fi
}

# Detect which package manager to use (prefer yarn if available)
get_pkg_manager() {
    if command -v yarn &> /dev/null; then
        echo "yarn"
    elif command -v npm &> /dev/null; then
        echo "npm"
    else
        echo ""
    fi
}

get_backend_command() {
    if command -v uv &> /dev/null; then
        echo "uv run elastic-demo-starter-backend"
    else
        echo -e "${YELLOW}⚠️  uv not found. Falling back to system Python.${NC}"
        echo "  Install uv for faster, reproducible installs: https://docs.astral.sh/uv/"
        echo "python run.py"
    fi
}

cmd_start() {
    ensure_dirs
    check_dependencies
    read_env_ports
    
    echo -e "${BLUE}🚀 Starting Elastic Demo Starter...${NC}"
    echo ""
    
    local ports_changed=false
    
    # -------------------------------------------------------------------------
    # Start Backend
    # -------------------------------------------------------------------------
    if is_running "$BACKEND_PID_FILE"; then
        echo -e "${YELLOW}⚠️  Backend already running (PID: $(get_pid $BACKEND_PID_FILE))${NC}"
    else
        # Check if configured port is available
        if ! is_port_available "$BACKEND_PORT"; then
            local old_port=$BACKEND_PORT
            BACKEND_PORT=$(find_available_port "$BACKEND_PORT")
            
            if [ -z "$BACKEND_PORT" ]; then
                echo -e "${RED}❌ Could not find available port for backend (tried $old_port-$((old_port+99)))${NC}"
                exit 1
            fi
            
            echo -e "${YELLOW}⚠️  Port $old_port in use, using $BACKEND_PORT instead${NC}"
            update_env_value "PORT" "$BACKEND_PORT"
            ports_changed=true
        fi
        
        echo -e "Starting backend on port ${GREEN}$BACKEND_PORT${NC}..."
        cd backend
        local backend_cmd
        backend_cmd=$(get_backend_command)
        PORT=$BACKEND_PORT nohup bash -c "$backend_cmd" > "../$LOG_DIR/backend.log" 2>&1 &
        echo $! > "../$BACKEND_PID_FILE"
        cd ..
        echo -e "${GREEN}✅ Backend started${NC} (PID: $(get_pid $BACKEND_PID_FILE))"
    fi
    
    # -------------------------------------------------------------------------
    # Start Frontend
    # -------------------------------------------------------------------------
    if is_running "$FRONTEND_PID_FILE"; then
        echo -e "${YELLOW}⚠️  Frontend already running (PID: $(get_pid $FRONTEND_PID_FILE))${NC}"
    else
        # Check if configured port is available
        if ! is_port_available "$FRONTEND_PORT"; then
            local old_port=$FRONTEND_PORT
            FRONTEND_PORT=$(find_available_port "$FRONTEND_PORT")
            
            if [ -z "$FRONTEND_PORT" ]; then
                echo -e "${RED}❌ Could not find available port for frontend (tried $old_port-$((old_port+99)))${NC}"
                exit 1
            fi
            
            echo -e "${YELLOW}⚠️  Port $old_port in use, using $FRONTEND_PORT instead${NC}"
            update_env_value "FRONTEND_PORT" "$FRONTEND_PORT"
            ports_changed=true
        fi
        
        echo -e "Starting frontend on port ${GREEN}$FRONTEND_PORT${NC}..."
        cd frontend
        # Detect package manager (prefer yarn, fall back to npm)
        local pkg_manager=$(get_pkg_manager)
        if [ -z "$pkg_manager" ]; then
            echo -e "${RED}❌ No package manager found (yarn or npm)${NC}"
            exit 1
        fi
        # Use --strictPort so Vite fails instead of silently switching ports
        # Pass BACKEND_PORT so vite proxy knows where to proxy API requests
        if [ "$pkg_manager" = "yarn" ]; then
            VITE_BACKEND_PORT=$BACKEND_PORT nohup yarn dev --port $FRONTEND_PORT --strictPort > "../$LOG_DIR/frontend.log" 2>&1 &
        else
            VITE_BACKEND_PORT=$BACKEND_PORT nohup npm run dev -- --port $FRONTEND_PORT --strictPort > "../$LOG_DIR/frontend.log" 2>&1 &
        fi
        echo $! > "../$FRONTEND_PID_FILE"
        cd ..
        echo -e "${GREEN}✅ Frontend started${NC} (PID: $(get_pid $FRONTEND_PID_FILE))"
    fi
    
    # -------------------------------------------------------------------------
    # Summary
    # -------------------------------------------------------------------------
    echo ""
    if [ "$ports_changed" = true ]; then
        echo -e "${YELLOW}📝 Updated backend/.env with new port(s)${NC}"
    fi
    
    echo -e "${GREEN}Servers starting...${NC}"
    echo -e "   Backend:  ${BLUE}http://localhost:$BACKEND_PORT${NC}"
    echo -e "   Frontend: ${BLUE}http://localhost:$FRONTEND_PORT${NC}"
    echo ""
    echo -e "Run ${YELLOW}./dev logs${NC} to see output"
    echo -e "Run ${YELLOW}./dev stop${NC} to stop servers"
    
    # Wait a moment then check if they're actually running
    sleep 2
    local failed=false
    
    if ! is_running "$BACKEND_PID_FILE"; then
        echo ""
        echo -e "${RED}⚠️  Backend failed to start${NC}"
        echo -e "${DIM}   Check: cat $LOG_DIR/backend.log${NC}"
        failed=true
    fi
    
    if ! is_running "$FRONTEND_PID_FILE"; then
        echo ""
        echo -e "${RED}⚠️  Frontend failed to start${NC}"
        echo -e "${DIM}   Check: cat $LOG_DIR/frontend.log${NC}"
        failed=true
    fi
    
    if [ "$failed" = false ]; then
        # Save the actual ports being used for other commands
        echo "$BACKEND_PORT" > "$PID_DIR/backend.port"
        echo "$FRONTEND_PORT" > "$PID_DIR/frontend.port"
    fi
}

cmd_stop() {
    read_env_ports
    
    echo -e "${BLUE}Stopping servers...${NC}"
    
    if is_running "$BACKEND_PID_FILE"; then
        local pid=$(get_pid "$BACKEND_PID_FILE")
        kill "$pid" 2>/dev/null || true
        rm -f "$BACKEND_PID_FILE"
        echo -e "${GREEN}✅ Backend stopped${NC}"
    else
        echo -e "${YELLOW}Backend not running${NC}"
    fi
    
    if is_running "$FRONTEND_PID_FILE"; then
        local pid=$(get_pid "$FRONTEND_PID_FILE")
        kill "$pid" 2>/dev/null || true
        # Also kill any child processes (vite spawns children)
        pkill -P "$pid" 2>/dev/null || true
        rm -f "$FRONTEND_PID_FILE"
        echo -e "${GREEN}✅ Frontend stopped${NC}"
    else
        echo -e "${YELLOW}Frontend not running${NC}"
    fi
    
    # Clean up port files
    rm -f "$PID_DIR/backend.port" "$PID_DIR/frontend.port"
    
    # Clean up any orphaned processes on our ports
    # Only kill if ports are defined
    if [ -n "$BACKEND_PORT" ]; then
        lsof -ti:"$BACKEND_PORT" 2>/dev/null | xargs kill 2>/dev/null || true
    fi
    if [ -n "$FRONTEND_PORT" ]; then
        lsof -ti:"$FRONTEND_PORT" 2>/dev/null | xargs kill 2>/dev/null || true
    fi
    
    echo -e "${GREEN}All servers stopped${NC}"
}

cmd_restart() {
    cmd_stop
    sleep 1
    cmd_start
}

cmd_status() {
    read_env_ports
    
    # Try to read actual running ports
    local actual_backend_port=$BACKEND_PORT
    local actual_frontend_port=$FRONTEND_PORT
    
    if [ -f "$PID_DIR/backend.port" ]; then
        actual_backend_port=$(cat "$PID_DIR/backend.port")
    fi
    if [ -f "$PID_DIR/frontend.port" ]; then
        actual_frontend_port=$(cat "$PID_DIR/frontend.port")
    fi
    
    echo -e "${BLUE}Server Status${NC}"
    echo ""
    
    if is_running "$BACKEND_PID_FILE"; then
        echo -e "Backend:  ${GREEN}● Running${NC} (PID: $(get_pid $BACKEND_PID_FILE), port $actual_backend_port)"
    else
        echo -e "Backend:  ${RED}○ Stopped${NC}"
    fi
    
    if is_running "$FRONTEND_PID_FILE"; then
        echo -e "Frontend: ${GREEN}● Running${NC} (PID: $(get_pid $FRONTEND_PID_FILE), port $actual_frontend_port)"
    else
        echo -e "Frontend: ${RED}○ Stopped${NC}"
    fi
    
    echo ""
    
    # Check if ports are actually listening
    if lsof -i:"$actual_backend_port" > /dev/null 2>&1; then
        echo -e "Port $actual_backend_port: ${GREEN}listening${NC}"
    else
        echo -e "Port $actual_backend_port: ${RED}not listening${NC}"
    fi
    
    if lsof -i:"$actual_frontend_port" > /dev/null 2>&1; then
        echo -e "Port $actual_frontend_port: ${GREEN}listening${NC}"
    else
        echo -e "Port $actual_frontend_port: ${RED}not listening${NC}"
    fi
}

cmd_logs() {
    ensure_dirs
    
    echo -e "${BLUE}Tailing logs (Ctrl+C to exit)${NC}"
    echo -e "Backend log:  $LOG_DIR/backend.log"
    echo -e "Frontend log: $LOG_DIR/frontend.log"
    echo ""
    
    # Use tail to follow both log files
    tail -f "$LOG_DIR/backend.log" "$LOG_DIR/frontend.log" 2>/dev/null || {
        echo -e "${YELLOW}No logs yet. Start servers with: ./dev start${NC}"
    }
}

cmd_logs_snapshot() {
    local lines=${1:-50}
    ensure_dirs
    
    echo -e "${BLUE}=== Backend Logs (last $lines lines) ===${NC}"
    if [ -f "$LOG_DIR/backend.log" ]; then
        tail -n "$lines" "$LOG_DIR/backend.log" 2>/dev/null || echo "(empty)"
    else
        echo -e "${YELLOW}No backend log file${NC}"
    fi
    
    echo ""
    echo -e "${BLUE}=== Frontend Logs (last $lines lines) ===${NC}"
    if [ -f "$LOG_DIR/frontend.log" ]; then
        tail -n "$lines" "$LOG_DIR/frontend.log" 2>/dev/null || echo "(empty)"
    else
        echo -e "${YELLOW}No frontend log file${NC}"
    fi
}

cmd_open() {
    read_env_ports
    
    # Try to read actual running port
    local actual_frontend_port=$FRONTEND_PORT
    if [ -f "$PID_DIR/frontend.port" ]; then
        actual_frontend_port=$(cat "$PID_DIR/frontend.port")
    fi
    
    local url="http://localhost:$actual_frontend_port"
    echo -e "Opening ${BLUE}$url${NC}..."
    
    # Detect OS and open browser
    case "$(uname -s)" in
        Darwin*) open "$url" ;;
        Linux*) xdg-open "$url" 2>/dev/null || sensible-browser "$url" ;;
        MINGW*|CYGWIN*) start "$url" ;;
        *) echo "Please open $url in your browser" ;;
    esac
}

cmd_test_agent() {
    read_env_ports
    
    # Get actual running port
    local actual_backend_port=$BACKEND_PORT
    if [ -f "$PID_DIR/backend.port" ]; then
        actual_backend_port=$(cat "$PID_DIR/backend.port")
    fi
    
    echo -e "${BLUE}🤖 Testing Agent Builder Connection...${NC}"
    echo ""
    
    # Check if backend is running
    if ! is_running "$BACKEND_PID_FILE"; then
        echo -e "${RED}❌ Backend not running${NC}"
        echo -e "   Start with: ${BLUE}./dev start${NC}"
        exit 1
    fi
    
    # Step 1: Check agent health endpoint
    echo -e "Checking agent configuration..."
    local health_response
    health_response=$(curl -s --max-time 10 "http://localhost:$actual_backend_port/api/agent/health" 2>&1)
    
    if [ $? -ne 0 ]; then
        echo -e "${RED}❌ Could not reach backend${NC}"
        echo -e "   Error: $health_response"
        exit 1
    fi
    
    # Parse health response
    local agent_id=$(echo "$health_response" | grep -o '"agent_id":"[^"]*"' | cut -d'"' -f4)
    local kibana_configured=$(echo "$health_response" | grep -o '"kibana_configured":true')
    
    if [ -z "$kibana_configured" ]; then
        echo -e "${RED}❌ Kibana not configured${NC}"
        echo -e "   Run: ${BLUE}./setup.sh${NC} to configure"
        exit 1
    fi
    
    echo -e "✅ Agent ID: ${GREEN}$agent_id${NC}"
    echo -e "✅ Kibana: ${GREEN}configured${NC}"
    echo ""
    
    # Step 2: Send a test message
    echo -e "Sending test message..."
    local test_response
    test_response=$(curl -s --max-time 30 "http://localhost:$actual_backend_port/api/agent/chat" \
        -H "Content-Type: application/json" \
        -d '{"input": "Hello, please respond briefly."}' 2>&1)
    
    # Check for common errors in response
    if echo "$test_response" | grep -q '"error"'; then
        local error_msg=$(echo "$test_response" | grep -o '"message":"[^"]*"' | head -1 | cut -d'"' -f4)
        echo ""
        echo -e "${RED}❌ Agent Error${NC}"
        echo -e "   $error_msg"
        echo ""
        
        # Provide helpful guidance based on error
        if echo "$test_response" | grep -qi "401\|unauthorized\|authenticate"; then
            echo -e "${YELLOW}Likely cause:${NC} Invalid API Key"
            echo -e "${YELLOW}Fix:${NC} Regenerate API key in Kibana and run ./setup.sh"
        elif echo "$test_response" | grep -qi "not found"; then
            echo -e "${YELLOW}Likely cause:${NC} Agent ID doesn't exist"
            echo -e "${YELLOW}Fix:${NC} Run ./setup.sh to list and select valid agents"
        elif echo "$test_response" | grep -qi "resolve\|connection\|connect"; then
            echo -e "${YELLOW}Likely cause:${NC} Cannot reach Kibana"
            echo -e "${YELLOW}Fix:${NC} Check KIBANA_URL in backend/.env"
        fi
        
        echo ""
        echo -e "See: ${BLUE}hive-mind/troubleshooting/AGENT_BUILDER_ERROR_REFERENCE.md${NC}"
        exit 1
    fi
    
    # Check for successful response (look for message_complete event)
    if echo "$test_response" | grep -q "message_complete\|message_chunk"; then
        echo -e "${GREEN}✅ Agent responded successfully!${NC}"
        echo ""
        
        # Try to extract a preview of the response
        local preview=$(echo "$test_response" | grep -o '"text_chunk":"[^"]*"' | head -3 | cut -d'"' -f4 | tr -d '\n')
        if [ -n "$preview" ]; then
            echo -e "${DIM}Response preview: ${preview:0:100}...${NC}"
        fi
    else
        echo -e "${YELLOW}⚠️  Response received but format unexpected${NC}"
        echo -e "${DIM}First 200 chars: ${test_response:0:200}${NC}"
    fi
    
    echo ""
    echo -e "${GREEN}✅ Agent Builder connection working!${NC}"
}

cmd_verify() {
    echo -e "${BLUE}🔍 Verifying setup...${NC}"
    echo ""
    
    local all_pass=true
    
    # Check 1: .setup-complete marker
    if [ -f ".setup-complete" ]; then
        echo -e "✅ Setup completed ($(grep timestamp .setup-complete | cut -d' ' -f2))"
    else
        echo -e "${RED}❌ Setup not complete${NC} - run ./setup.sh first"
        all_pass=false
    fi
    
    # Check 2: backend/.env exists
    if [ -f "backend/.env" ]; then
        echo -e "✅ Backend configuration exists"
    else
        echo -e "${RED}❌ Missing backend/.env${NC}"
        all_pass=false
    fi
    
    # Check 3: uv installed
    if command -v uv &> /dev/null; then
        echo -e "✅ uv installed"
    else
        echo -e "${RED}❌ Missing uv${NC}"
        all_pass=false
    fi
    
    # Check 4: node_modules
    if [ -d "frontend/node_modules" ]; then
        echo -e "✅ Frontend dependencies"
    else
        echo -e "${RED}❌ Missing frontend/node_modules${NC}"
        all_pass=false
    fi
    
    # Check 5: hive-mind submodule
    if is_hive_mind_loaded; then
        echo -e "✅ Hive-mind knowledge base"
    else
        echo -e "${YELLOW}⚠️  Hive-mind empty${NC} - run: git submodule update --init"
    fi
    
    # Check 6: Backend import check
    if command -v uv &> /dev/null; then
        if (cd backend && uv run python -c "from app.main import app" > /dev/null 2>&1); then
            echo -e "✅ Backend imports OK"
        else
            echo -e "${RED}❌ Backend import failed (missing dependencies?)${NC}"
            echo -e "${DIM}   Run: cd backend && uv sync${NC}"
            all_pass=false
        fi
    fi

    # Check 7: If servers running, ping health
    read_env_ports
    local actual_backend_port=$BACKEND_PORT
    if [ -f "$PID_DIR/backend.port" ]; then
        actual_backend_port=$(cat "$PID_DIR/backend.port")
    fi
    
    if is_running "$BACKEND_PID_FILE"; then
        # Try to ping health endpoint
        if curl -s --max-time 3 "http://localhost:$actual_backend_port/health" > /dev/null 2>&1; then
            echo -e "✅ Backend health check passed"
        else
            echo -e "${YELLOW}⚠️  Backend running but health check failed${NC}"
            if [ -f "$LOG_DIR/backend.log" ]; then
                echo -e "${DIM}   Recent backend log:${NC}"
                tail -5 "$LOG_DIR/backend.log" 2>/dev/null | while IFS= read -r line; do
                    echo -e "${DIM}   ${line}${NC}"
                done
            fi
        fi
    else
        echo -e "${DIM}ℹ️  Servers not running (start with ./dev start)${NC}"
    fi
    
    echo ""
    if [ "$all_pass" = true ]; then
        echo -e "${GREEN}✅ All checks passed!${NC}"
        return 0
    else
        echo -e "${RED}❌ Some checks failed${NC}"
        echo -e "${DIM}   Run ./setup.sh to fix${NC}"
        return 1
    fi
}

cmd_use_ootb() {
    echo -e "${BLUE}🔧 Configuring Shared OOTB Project...${NC}"
    echo ""
    
    # Check if gh CLI is available
    if ! command -v gh &> /dev/null; then
        echo -e "${RED}❌ GitHub CLI (gh) is required${NC}"
        echo ""
        echo "Install with:"
        echo "  macOS:   brew install gh"
        echo "  Linux:   https://github.com/cli/cli/blob/trunk/docs/install_linux.md"
        echo "  Windows: winget install GitHub.cli"
        echo ""
        echo "Then authenticate: gh auth login"
        exit 1
    fi
    
    # Check if authenticated
    if ! gh auth status &> /dev/null; then
        echo -e "${RED}❌ Not authenticated with GitHub${NC}"
        echo ""
        echo "Run: gh auth login"
        exit 1
    fi
    
    echo -e "Fetching OOTB credentials from GitHub..."
    
    # Fetch variables from GitHub
    local es_url kibana_url api_key
    es_url=$(gh variable get OOTB_ELASTICSEARCH_URL 2>/dev/null) || {
        echo -e "${RED}❌ Could not fetch OOTB_ELASTICSEARCH_URL${NC}"
        echo "   Make sure you have access to the elastic/elastic-demo-starter repository."
        echo "   Repository variables are only visible to collaborators with read access."
        echo ""
        echo "   See: docs/SHARED_SERVERLESS_PROJECT.md for manual setup instructions."
        exit 1
    }
    
    kibana_url=$(gh variable get OOTB_KIBANA_URL 2>/dev/null) || {
        echo -e "${RED}❌ Could not fetch OOTB_KIBANA_URL${NC}"
        exit 1
    }
    
    api_key=$(gh variable get OOTB_READONLY_API_KEY 2>/dev/null) || {
        echo -e "${RED}❌ Could not fetch OOTB_READONLY_API_KEY${NC}"
        exit 1
    }
    
    echo -e "${GREEN}✅ Credentials fetched${NC}"
    
    # Create or update backend/.env
    local env_file="backend/.env"
    
    if [ ! -f "$env_file" ]; then
        # Create from example if it exists
        if [ -f "backend/.env.example" ]; then
            cp "backend/.env.example" "$env_file"
            echo -e "Created $env_file from template"
        else
            touch "$env_file"
            echo -e "Created $env_file"
        fi
    fi
    
    # Update the values
    update_env_value "ELASTICSEARCH_URL" "$es_url"
    update_env_value "ELASTIC_API_KEY" "$api_key"
    update_env_value "KIBANA_URL" "$kibana_url"
    
    echo ""
    echo -e "${GREEN}✅ Configured backend/.env with OOTB credentials${NC}"
    echo ""
    echo -e "   Elasticsearch: ${BLUE}$es_url${NC}"
    echo -e "   Kibana:        ${BLUE}$kibana_url${NC}"
